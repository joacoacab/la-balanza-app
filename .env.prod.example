# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=cambiar-por-clave-segura-generada
ALLOWED_HOSTS=api.labalanza.siracnetwork.com
CSRF_TRUSTED_ORIGINS=https://labalanza.siracnetwork.com,https://api.labalanza.siracnetwork.com

# Base de datos (Django)
DB_NAME=labalanza
DB_USER=labalanza
DB_PASSWORD=cambiar-por-password-seguro
DB_HOST=db
DB_PORT=5432

# PostgreSQL (imagen oficial)
POSTGRES_DB=labalanza
POSTGRES_USER=labalanza
POSTGRES_PASSWORD=cambiar-por-password-seguro

# Email — AWS SES (us-east-1)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=cambiar-por-smtp-user-de-ses
EMAIL_HOST_PASSWORD=cambiar-por-smtp-password-de-ses
DEFAULT_FROM_EMAIL=noreply@siracnetwork.com

# MercadoPago
MP_ACCESS_TOKEN=cambiar-por-access-token
MP_WEBHOOK_SECRET=cambiar-por-webhook-secret
APP_URL=https://labalanza.siracnetwork.com

# Google OAuth
GOOGLE_CLIENT_ID=cambiar-por-client-id
